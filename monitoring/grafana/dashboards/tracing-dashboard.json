{
  "id": null,
  "uid": "swaptrade-tracing",
  "title": "SwapTrade — Distributed Tracing",
  "tags": ["swaptrade", "tracing", "opentelemetry"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate by Route",
      "description": "Total HTTP requests per second grouped by method + route. 100 % coverage indicates all requests are being traced.",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (method, route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{method}} {{route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "P50 / P95 / P99 Request Latency",
      "description": "Latency percentiles. The P99 line indicates worst-case user experience. Alert fires at P95 > 2 s.",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "P99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Error Rate (5xx)",
      "description": "Percentage of HTTP requests returning 5xx status codes. Alert fires above 5 %.",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m])) * 100",
          "legendFormat": "5xx error %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percent" }
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Database Query Latency (P95)",
      "description": "P95 TypeORM query duration by operation. Alert fires above 500 ms.",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, operation, table) (rate(database_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{operation}} {{table}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Requests (last 5 m)",
      "gridPos": { "x": 0, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total[5m]))",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Error Count (last 5 m)",
      "gridPos": { "x": 6, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[5m]))",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "type": "stat",
      "title": "DB Query Count (last 5 m)",
      "gridPos": { "x": 12, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(database_queries_total[5m]))",
          "legendFormat": "Queries",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "type": "stat",
      "title": "DB Error Count (last 5 m)",
      "gridPos": { "x": 18, "y": 16, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(database_queries_total{status=\"error\"}[5m]))",
          "legendFormat": "DB Errors",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "type": "text",
      "title": "Trace Exploration",
      "description": "Open the Jaeger UI to search and inspect individual traces.",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 3 },
      "options": {
        "content": "## Explore Traces\nOpen **[Jaeger UI](http://localhost:16686)** to search traces by service, operation, tag, or duration. Use the `traceId` from application logs to jump directly to a trace.",
        "mode": "markdown"
      }
    }
  ]
}
