# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swaptrade
DATABASE_SSL=false

# Redis
REDIS_URL=redis://localhost:6379
REDIS_TLS=false

# JWT (generate a secure secret for production!)
JWT_SECRET=your-super-secret-key-at-least-32-characters-long-change-in-production
JWT_EXPIRATION=1d

# Stellar
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# STELLAR_USDC_ISSUER=GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
STELLAR_POLLING_ENABLED=false

# Exchange Rate (optional)
# EXCHANGE_RATE_URL=https://api.exchangerate-api.com/v4/latest/USD

# Email (optional in development)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=noreply@swaptrade.com

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS
CORS_ORIGINS=*

# Logging
LOG_LEVEL=debug
